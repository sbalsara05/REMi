# REMi environment (local)
# Copy and fill in secrets:
#   cp env.local.example env.local
#
# All LibreChat / Docker settings live here at the repo root.

HOST=localhost
PORT=3080

# Overridden by docker-compose to mongodb://mongodb:27017 when using Docker
MONGO_URI=mongodb://127.0.0.1:27017/LibreChat

DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

NO_INDEX=true
TRUST_PROXY=1

DEBUG_LOGGING=false
DEBUG_CONSOLE=false

# Required — https://openrouter.ai/keys
OPENROUTER_KEY=

APP_TITLE=REMi

CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0
CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb

SEARCH=true
MEILI_NO_ANALYTICS=true
# Overridden by docker-compose to http://meilisearch:7700 when using Docker
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=DrhYf7zENyR6AlUCKmnz0eYASOQdl6zxH7s7MKFSfFCt

ALLOW_REGISTRATION=true
JWT_SECRET=16f8c0ef4a5d391b26034086c628469d3f9f497f08163ab9b40137092f2909ef
JWT_REFRESH_SECRET=eaa5191f2914e30b9387fd84e254e4ba6fc51b4654968a9b0803b456a54b8418

# Mac Docker volume permissions (scripts/start-mac.sh sets UID/GID from id -u / id -g)
